use std::fmt::Display;

use axum::{Json, http::StatusCode, response::IntoResponse};
use serde::Serialize;

#[derive(Debug, Serialize)]
pub struct CommonError {
    pub message: String,
    #[serde(skip)] // Hide from response
    pub code: u32,
}

impl Display for CommonError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "Error: {}, Code: {}", self.message, self.code)
    }
}

#[derive(Debug, Serialize)]
struct ErrorResponse {
    status_code: u16,
    message: String,
    error: String
}

#[derive(Debug)]
pub struct ApiError(CommonError);

impl From<CommonError> for ApiError {
    fn from(value: CommonError) -> Self {
        ApiError(value)
    }
}

impl Display for ApiError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self.0)
    }
}

impl IntoResponse for ApiError {
    fn into_response(self) -> axum::response::Response {
        let status = match self.0.code {
            0 => StatusCode::BAD_REQUEST,
            1 => StatusCode::NOT_FOUND,
            2 => StatusCode::INTERNAL_SERVER_ERROR,
            _ => StatusCode::BAD_REQUEST,
        };

        let body: ErrorResponse = ErrorResponse { status_code: status.as_u16(), message: self.0.message, error: status.canonical_reason().unwrap_or("Error").to_string() };
        (status, Json(body)).into_response()
    }
}

#[derive(Debug)]
pub struct RepositoryError {
    pub message: String,
    pub code: u32
}

impl Into<CommonError> for RepositoryError {
    fn into(self) -> CommonError {
        CommonError {
            message: self.message,
            code: self.code
        }
    }
}
