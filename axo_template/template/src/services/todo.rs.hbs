use std::sync::Arc;

use async_trait::async_trait;

use crate::domain::{
    error::CommonError,
    models::todo::{CreateTodo, Todo},
    repositories::{
        repository::ResultPaging,
        todo::{TodoQueryParams, TodoRepository},
    },
    services::todo::TodoService,
};

#[derive(Clone)]
pub struct TodoServiceImpl {
    pub repository: Arc<dyn TodoRepository>,
}

impl TodoServiceImpl {
    pub fn new(todo_repository: Arc<dyn TodoRepository>) -> Self {
        TodoServiceImpl {
            repository: todo_repository,
        }
    }
}

#[async_trait]
impl TodoService for TodoServiceImpl {
    async fn create(&self, todo: CreateTodo) -> Result<Todo, CommonError> {
        let cloned = todo.clone();
        self.repository
            .create(&cloned)
            .await
            .map_err(|e| -> CommonError { e.into() })
    }

    async fn list(&self, params: TodoQueryParams) -> Result<ResultPaging<Todo>, CommonError> {
        self.repository
            .list(&params)
            .await
            .map_err(|e| -> CommonError { e.into() })
    }

    async fn get(&self, todo_id: i32) -> Result<Todo, CommonError> {
        self.repository
            .get(todo_id)
            .await
            .map_err(|e| -> CommonError { e.into() })
    }

    async fn delete(&self, todo_id: i32) -> Result<(), CommonError> {
        self.repository
            .delete(todo_id)
            .await
            .map_err(|e| -> CommonError { e.into() })
    }
}
